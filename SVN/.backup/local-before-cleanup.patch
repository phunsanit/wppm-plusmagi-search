-		// Use $wpdb->prepare() so the user ID is safely interpolated even
-		// though it is already cast to int above.
-		$where .= $wpdb->prepare(
-			" AND ( {$wpdb->posts}.post_status = 'publish' OR {$wpdb->posts}.post_author = %d ) ",
-			$current_user_id
-		);
-
-		return $where;
-	}
